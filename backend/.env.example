PORT=5001
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=<random_64_byte_hex>
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM=EventSpace your@email.com

# Paystack — obtain from dashboard.paystack.com → Settings → API Keys & Webhooks
# Use sk_test_ / pk_test_ keys during development; never commit live keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Set this to a random secret string, then enter the same value in the Paystack
# dashboard under Settings → API Keys & Webhooks → Webhook URL.
# Webhook URL: https://your-domain.com/api/payments/webhook
# For local development expose the server with: npx ngrok http 5001
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here
